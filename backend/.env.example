# ============================================
# CLIPMIND ENVIRONMENT VARIABLES
# ============================================

# SERVER
NODE_ENV=production
PORT=8080
BASE_URL=https://clipmind.com

# ============================================
# SUPABASE
# ============================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxx

# ============================================
# OPENAI (WHISPER - TRANSCRIÇÃO)
# ============================================
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# ============================================
# ANTHROPIC (CLAUDE HAIKU - ANÁLISE)
# ============================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ============================================
# MERCADO PAGO (PAGAMENTO)
# ============================================
MERCADO_PAGO_ACCESS_TOKEN=APP_xxxxxxxxxxxxx
MERCADO_PAGO_PUBLIC_KEY=APP_PUBLIC_xxxxxxxxxxxxx

# ============================================
# STORAGE E PROCESSAMENTO
# ============================================
VIDEO_RETENTION_DAYS=30
MAX_VIDEO_SIZE_MB=500
TEMP_DIR=/tmp

# ============================================
# SEGURANÇA
# ============================================
WEBHOOK_SECRET=seu_secret_aleatorio_muito_seguro_aqui

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info

# ============================================
# NOTAS DE CONFIGURAÇÃO
# ============================================
# 1. SUPABASE: Obter em https://app.supabase.com → Settings → API
# 2. OPENAI: Obter em https://platform.openai.com → API keys
# 3. ANTHROPIC: Obter em https://console.anthropic.com → API keys
# 4. MERCADO PAGO: Obter em https://www.mercadopago.com.br → Devs
# 5. WEBHOOK_SECRET: Gerar um string aleatório seguro (openssl rand -base64 32)
